AUTH_URL=http://localhost:5173/api/auth
NEXTAUTH_URL=http://localhost:5173/api/auth
AUTH_SECRET=your_auth_secret_here
SITE_ORIGIN=http://localhost:5173

# Database (choose ONE)
# For MySQL/MariaDB, prefer a single DATABASE_URL like:
#   mysql://USERNAME:PASSWORD@HOST:3306/DBNAME
# or mariadb://USERNAME:PASSWORD@HOST:3306/DBNAME
DATABASE_URL=

# SMTP settings (use a dedicated sending account and keep credentials secret)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Comic Replies" <no-reply@example.com>

# Optional: override sqlite DB path
# DATABASE_PATH=/full/path/to/data/db.db

# Other DB envs (legacy; not used when DATABASE_URL is set)
DB_USER=
DB_PASS=
DB_SERVER=
DB_NAME=
