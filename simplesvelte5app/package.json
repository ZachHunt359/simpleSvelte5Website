{
	"name": "simplesvelte5app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "npm run generate:panels && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"generate:panels": "node scripts/generate-panels-json.js",
		"update-panels": "node scripts/generate-panels-json.js",
		"migrate": "node scripts/apply-migrations.js"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^5.7.2",
		"@sveltejs/kit": "^2.21.4",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@types/bcrypt": "^5.0.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/mssql": "^9.1.7",
		"@types/node": "^22.15.20",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0"
	},
	"dependencies": {
		"@auth/core": "^0.39.1",
		"@auth/sveltekit": "^1.9.2",
		"@fortawesome/free-solid-svg-icons": "6.2.0",
		"@iconify/svelte": "^5.0.0",
		"@sveltejs/adapter-node": "^5.2.12",
		"@types/debug": "4.1.7",
		"bcrypt": "^6.0.0",
		"bcryptjs": "^3.0.2",
		"better-sqlite3": "^11.10.0",
		"cors": "^2.8.5",
		"debug": "4.3.4",
		"express": "^5.1.0",
		"mssql": "^11.0.1",
		"multer": "^2.0.1",
		"mysql2": "^3.3.0",
		"neverthrow": "5.0.0",
		"nodemailer": "^6.10.1",
		"svelte-fa": "3.0.3"
	}
}
