# Example environment variables for local development.
# Copy this file to .env and fill in real values (do NOT commit .env to git).

# Admin seeding credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Base URL for test-login script
APP_URL=http://localhost:5173

# Optional: override node environment
NODE_ENV=development
# Environment Variables Example
# Copy this file to .env and fill in your actual values
# Also create environment-specific files like .env.development, .env.production

# App Configuration
SITE_ORIGIN=https://your-domain.com
AUTH_URL=https://your-domain.com/api/auth
NEXTAUTH_URL=https://your-domain.com/api/auth
AUTH_SECRET=your-auth-secret-here

# Database Configuration
DATABASE_URL=mysql://username:password@host:3306/database_name

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Your Name <your-email@gmail.com>"

# Email Configuration (IMAP - for checking sent emails)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-app-password
IMAP_SENT_CANDIDATES="[Gmail]/Sent Mail","Sent","Sent Items","INBOX.Sent"

# Upload Configuration
BODY_SIZE_LIMIT=100M

# Development-specific (for .env.development)
# DATABASE_URL=mysql://dev_user:dev_pass@127.0.0.1:3306/dev_database
# DATABASE_URL=sqlite:./dev-database.sqlite

# Production-specific (for .env.production)
# NODE_ENV=production

# Staging-specific (for .env.staging)
# NODE_ENV=production