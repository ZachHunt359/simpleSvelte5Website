{
  "name": "simpleSvelte5Website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npm run generate:panels && vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "generate:panels": "node scripts/generate-panels-json.js",
    "update-panels": "node scripts/generate-panels-json.js",
    "ensure-youtube": "node scripts/ensure-youtube-entries.js",
    "test:navigation": "node scripts/test-navigation-logic.js",
    "migrate": "node scripts/apply-migrations.js",
    "seed:admin": "node scripts/seed-admin-mysql.js",
    "seed:admin:dev": "cross-env NODE_ENV=development node scripts/seed-admin-mysql.js",
    "seed:admin:staging": "cross-env NODE_ENV=staging node scripts/seed-admin-mysql.js",
    "seed:admin:prod": "cross-env NODE_ENV=production node scripts/seed-admin-mysql.js",
    "test:login": "node scripts/test-login-http.js http://localhost:5173",
    "test:login:dev": "cross-env NODE_ENV=development node scripts/test-login-http.js http://localhost:5173",
    "test": "vitest"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^5.7.2",
    "@sveltejs/kit": "^2.21.4",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@testing-library/svelte": "^4.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "^9.1.7",
    "@types/node": "^22.15.20",
    "cross-env": "^7.0.3",
    "jsdom": "^26.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^1.2.2"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@auth/sveltekit": "^1.11.1",
    "@fortawesome/free-solid-svg-icons": "6.2.0",
    "@iconify/svelte": "^5.0.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@tailwindcss/forms": "^0.5.10",
    "@types/debug": "4.1.7",
    "@uppy/core": "^5.1.1",
    "@uppy/dashboard": "^5.0.3",
    "@uppy/svelte": "^5.0.2",
    "@uppy/thumbnail-generator": "^5.0.2",
    "@uppy/xhr-upload": "^5.0.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "debug": "4.3.4",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "flatpickr": "^4.6.13",
    "mssql": "^11.0.1",
    "multer": "^2.0.1",
    "mysql2": "^3.3.0",
    "neverthrow": "5.0.0",
    "nodemailer": "^7.0.10",
    "svelte-dnd-action": "^0.9.66",
    "svelte-fa": "3.0.3"
  }
}
